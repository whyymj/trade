# =====================================================
# FundProphet 微服务环境变量配置模板
# =====================================================
# 使用方法:
# 1. 复制此文件为 .env
# 2. 修改以下配置（特别是密码和 API 密钥）
# 3. 运行 ./start-microservices.sh 启动服务
# =====================================================

# =====================================================
# 数据库配置 (MySQL)
# =====================================================
# MySQL root 用户密码（必须修改）
DB_ROOT_PASSWORD=your_secure_root_password_here

# 应用数据库用户（必须修改）
DB_USER=funduser

# 应用数据库密码（必须修改）
DB_PASSWORD=your_secure_password_here

# 数据库名称（通常不需要修改）
DB_NAME=trade_cache

# 数据库主机（服务间通信使用 docker 服务名）
DB_HOST=mysql

# 数据库端口
DB_PORT=3306

# =====================================================
# Redis 配置
# =====================================================
# Redis 连接 URL（服务间通信使用 docker 服务名）
REDIS_URL=redis://redis:6379

# Redis 密码（如需启用 Redis 密码认证，取消注释并设置）
# REDIS_PASSWORD=

# =====================================================
# LLM API 密钥（必须配置，否则 AI 功能不可用）
# =====================================================
# DeepSeek API 密钥
# 获取地址: https://platform.deepseek.com/apikeys
DEEPSEEK_API_KEY=sk-your_deepseek_api_key_here

# MiniMax API 密钥
# 获取地址: https://api.minimax.chat
MINIMAX_API_KEY=your_minimax_api_key_here

# =====================================================
# 服务间通信 URL（通常不需要修改）
# =====================================================
# 这些 URL 用于服务间内部通信，使用 Docker 服务名
# 不要使用 localhost，因为容器内 localhost 指向容器本身

FUND_SERVICE_URL=http://fund-service:8002
STOCK_SERVICE_URL=http://stock-service:8001
NEWS_SERVICE_URL=http://news-service:8003
MARKET_SERVICE_URL=http://market-service:8004
FUND_INTEL_SERVICE_URL=http://fund-intel-service:8005
LLM_SERVICE_URL=http://llm-service:8006

# =====================================================
# 日志配置
# =====================================================
# 日志级别: DEBUG, INFO, WARNING, ERROR, CRITICAL
# 生产环境建议使用 INFO 或 WARNING
LOG_LEVEL=INFO

# =====================================================
# 应用配置
# =====================================================
# Flask 调试模式（生产环境必须设置为 0）
FLASK_DEBUG=0

# Python 无缓冲输出（推荐设置为 1）
PYTHONUNBUFFERED=1

# =====================================================
# Docker Registry（生产环境推送镜像使用）
# =====================================================
# Docker 镜像仓库地址（开发环境不需要）
REGISTRY_URL=registry.example.com

# =====================================================
# 外部服务配置（可选）
# =====================================================
# akshare 超时设置（秒）
AKSHARE_TIMEOUT=30

# 新闻爬取间隔（秒）
NEWS_CRAWL_INTERVAL=3600

# 市场数据同步间隔（秒）
MARKET_SYNC_INTERVAL=7200

# =====================================================
# 性能配置（可选）
# =====================================================
# 数据库连接池大小
DB_POOL_SIZE=10

# 数据库连接池最大溢出数
DB_MAX_OVERFLOW=20

# Redis 连接池大小
REDIS_POOL_SIZE=10

# =====================================================
# 安全配置（可选）
# =====================================================
# 允许的 CORS 源（多个用逗号分隔）
CORS_ORIGINS=http://localhost:5173,http://localhost:80

# JWT 密钥（如需启用 JWT 认证）
# JWT_SECRET_KEY=your_jwt_secret_key_here

# =====================================================
# 监控配置（可选）
# =====================================================
# Prometheus 指标端口
# METRICS_PORT=9090

# 是否启用详细日志（调试用）
VERBOSE_LOGGING=false

# =====================================================
# 注意事项
# =====================================================
# 1. 不要将 .env 文件提交到版本控制
# 2. 生产环境必须修改所有默认密码
# 3. 确保 API 密钥正确，否则 AI 功能无法使用
# 4. 修改配置后需要重启服务才能生效
# 5. 查看完整部署文档: docs/DEPLOYMENT.md
# =====================================================